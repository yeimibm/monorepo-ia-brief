# =============================================================================
# CONFIGURACIÓN DE ENVIRONMENTS - E-COMMERCE EVENT-DRIVEN
# =============================================================================
# Copiar este archivo a .env en desarrollo local
# En producción, usar variables de entorno del sistema

# =============================================================================
# POSTGRESQL - BASE DE DATOS DE ÓRDENES
# =============================================================================
ORDERS_DB_USER=orders_user
ORDERS_DB_PASSWORD=orders_password
# Conexión interna (desde contenedores): postgresql://orders_user:orders_password@orders-db:5432/orders_db
# Conexión externa (desde máquina host): postgresql://orders_user:orders_password@localhost:5432/orders_db

# =============================================================================
# POSTGRESQL - BASE DE DATOS DE INVENTARIO
# =============================================================================
INVENTORY_DB_USER=inventory_user
INVENTORY_DB_PASSWORD=inventory_password
# Conexión interna (desde contenedores): postgresql://inventory_user:inventory_password@inventory-db:5432/inventory_db
# Conexión externa (desde máquina host): postgresql://inventory_user:inventory_password@localhost:5433/inventory_db

# =============================================================================
# KAFKA / REDPANDA
# =============================================================================
# Brokers (desde contenedores)
KAFKA_BROKERS=kafka:9092
# Para conectar desde máquina host, usar: localhost:9092

# Topics (se crean automáticamente si REDPANDA_AUTO_CREATE_TOPICS_ENABLED=true)
KAFKA_TOPIC_ORDER_CREATED=order.created
KAFKA_TOPIC_INVENTORY_RESERVED=inventory.reserved
KAFKA_TOPIC_INVENTORY_REJECTED=inventory.rejected

# Consumer groups
KAFKA_CONSUMER_GROUP_INVENTORY=inventory-service-group
KAFKA_CONSUMER_GROUP_ORDER=order-service-group

# Configuración del cliente
KAFKA_CLIENT_ID=ecommerce-service
KAFKA_CONNECTION_TIMEOUT=10000
KAFKA_REQUEST_TIMEOUT=30000

# =============================================================================
# ORDER SERVICE
# =============================================================================
ORDER_SERVICE_PORT=3001
ORDER_SERVICE_NODE_ENV=development
ORDER_SERVICE_LOG_LEVEL=debug
# Cuando se implementen los servicios, descomenta:
# ORDER_SERVICE_DATABASE_URL=postgresql://orders_user:orders_password@orders-db:5432/orders_db

# =============================================================================
# INVENTORY SERVICE
# =============================================================================
INVENTORY_SERVICE_PORT=3002
INVENTORY_SERVICE_NODE_ENV=development
INVENTORY_SERVICE_LOG_LEVEL=debug
# Cuando se implementen los servicios, descomenta:
# INVENTORY_SERVICE_DATABASE_URL=postgresql://inventory_user:inventory_password@inventory-db:5432/inventory_db

# =============================================================================
# GENERAL
# =============================================================================
NODE_ENV=development
# Valores: development, staging, production

# =============================================================================
# DOCKER COMPOSE
# =============================================================================
# Variables de perfil para docker compose (comentadas para esta demo)
# COMPOSE_PROFILES=dev,debug
